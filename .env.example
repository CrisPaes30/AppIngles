# =============================================================================
# AppIngles — modelo de variáveis de ambiente
# Copie para ".env" na raiz do repo e preencha com valores reais.
#   cp .env.example .env
# O ".env" nunca deve ser commitado (está no .gitignore).
# =============================================================================

# --- Timezone ----------------------------------------------------------------
TZ=America/Sao_Paulo

# --- Oracle Database Free -----------------------------------------------------
# Gere com: openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24
ORACLE_PASSWORD=
ORACLE_APP_USER=homelab
ORACLE_APP_PASSWORD=

# --- Backend Spring Boot -------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:oracle:thin:@oracle:1521/FREEPDB1
DB_USERNAME=homelab
DB_PASSWORD=

# Gere com: openssl rand -base64 48
JWT_SECRET=

# Domínio(s) do frontend publicado na Vercel, separados por vírgula
CORS_ALLOWED_ORIGINS=https://seu-app.vercel.app

# mock (sem custo, sem chave) | openai (requer OPENAI_API_KEY)
AI_PROVIDER=mock
DICTIONARY_PROVIDER=mock
OPENAI_API_KEY=

# Client ID OAuth do Google (Firebase console > Authentication > Sign-in method > Google)
GOOGLE_CLIENT_ID=

# --- DuckDNS + Caddy (exposição pública sem domínio pago) ----------------------
# Crie o subdomínio grátis em https://www.duckdns.org (ex.: "meuapp" vira
# meuapp.duckdns.org). Requer port-forward das portas 80 e 443 do roteador
# para o IP local (reservado) desta máquina.
DUCKDNS_SUBDOMAIN=
DUCKDNS_TOKEN=
